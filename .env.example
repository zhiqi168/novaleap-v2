# -----------------------------
# Runtime profile
# -----------------------------
TZ=Asia/Shanghai
SPRING_PROFILES_ACTIVE=prod

# -----------------------------
# Port publishing
# -----------------------------
FRONTEND_BIND_IP=0.0.0.0
FRONTEND_PORT=80
ADMIN_BIND_IP=0.0.0.0
ADMIN_PORT=8081
BACKEND_BIND_IP=127.0.0.1
BACKEND_PORT=8080
DATA_BIND_IP=127.0.0.1
MYSQL_PORT=3306
REDIS_PORT=6379

# -----------------------------
# MySQL container init
# -----------------------------
MYSQL_DATABASE=novaleap
MYSQL_ROOT_PASSWORD=replace-with-a-strong-root-password
MYSQL_USER=novaleap
MYSQL_PASSWORD=replace-with-a-strong-app-password

# -----------------------------
# Backend datasource
# Keep these aligned with MYSQL_USER / MYSQL_PASSWORD in Docker deployment.
# -----------------------------
SPRING_DATASOURCE_USERNAME=novaleap
SPRING_DATASOURCE_PASSWORD=replace-with-a-strong-app-password

# -----------------------------
# Redis
# Leave blank to disable password auth in local deployments.
# If you set REDIS_PASSWORD, also set SPRING_DATA_REDIS_PASSWORD to the same value.
# -----------------------------
REDIS_PASSWORD=
SPRING_DATA_REDIS_PASSWORD=

# -----------------------------
# AI provider
# Required: the backend cannot start without this key in the current codebase.
# -----------------------------
SPRING_AI_OPENAI_API_KEY=
SPRING_AI_OPENAI_BASE_URL=https://api.longcat.chat/openai
SPRING_AI_OPENAI_MAX_TOKENS=10000000
LONGCAT_MODEL=LongCat-Flash-Chat
LONGCAT_MODEL_FALLBACK=LongCat-Flash-Lite
NOVA_AI_QUOTA_DAILY_TOKEN_LIMIT=10000000
NOVA_AI_QUOTA_WARNING_RATIO=0.70
NOVA_AI_QUOTA_PROTECT_RATIO=0.85
NOVA_AI_QUOTA_LIMIT_RATIO=0.95
NOVA_AI_QUOTA_PER_MODEL_TOKEN_LIMIT=5000000
NOVA_AI_QUOTA_MODEL_USAGE_TTL_DAYS=2
NOVA_AI_GATEWAY_TIMEOUT_MS=15000
NOVA_AI_GATEWAY_MAX_RETRY_ATTEMPTS=2
NOVA_AI_GATEWAY_RETRY_BACKOFF_MS=350
NOVA_AI_GATEWAY_CIRCUIT_WINDOW_SECONDS=120
NOVA_AI_GATEWAY_CIRCUIT_FAILURE_THRESHOLD=5
NOVA_AI_GATEWAY_CIRCUIT_OPEN_SECONDS=90
NOVA_AI_GATEWAY_MIN_RESPONSE_TOKENS=128

# -----------------------------
# Security / auth
# -----------------------------
NOVA_JWT_SECRET=replace-with-a-64-char-random-secret
NOVA_ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-admin.vercel.app
NOVA_TURNSTILE_ENABLED=false
NOVA_TURNSTILE_SECRET=

# -----------------------------
# Email
# -----------------------------
NOVA_RESEND_API_KEY=
NOVA_RESEND_FROM=

# -----------------------------
# JVM
# -----------------------------
JAVA_TOOL_OPTIONS=-Xms128m -Xmx384m -XX:+UseG1GC

# -----------------------------
# Local non-Docker startup only (optional)
# Uncomment if you want to load the same .env into a local shell before running Spring Boot directly.
# -----------------------------
# SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/novaleap?useUnicode=true&characterEncoding=utf-8&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai
# SPRING_DATA_REDIS_HOST=localhost
# SPRING_DATA_REDIS_PORT=6379
